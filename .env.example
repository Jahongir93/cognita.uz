# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080
ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://gogame:yourpassword@localhost:5432/gogame?sslmode=disable
POSTGRES_DB=gogame
POSTGRES_USER=gogame
POSTGRES_PASSWORD=yourpassword

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=change-this-to-a-very-long-random-secret-in-production
JWT_EXPIRY_HOURS=24
REFRESH_EXPIRY_HOURS=168

# ─── Files ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Frontend env (create frontend/.env) ────────────────────────────────────
VITE_API_URL=http://localhost:8080
